<!DOCTYPE html>
<html lang="en">
    <%- include("../partials/head",{title:"Login"})%>
    <body>
        <header><h1>Login Page</h1>
        </header>
        <main>
        <form class="auth-form" action="/auth/login" method="post">
            <div>
                <label for="email">Email</label>
            <input type="email" name="email" id="email" />
        </div>
            <div><label for="password">Password</label>
            <input type="password" name="password" id="password" /></div>
            <div><label for="confirmPassword">Confirm Password</label>
            <input
                type="password"
                name="confirmPassword"
                id="confirmPassword"
            /></div>
            <button type="submit">Submit</button>
                <%- include("../partials/errors",{errors:locals?.errors})%>
        </form>
    </main>
        <%- include("../partials/aside",{active:"login"})%>
    </body>
</html>
